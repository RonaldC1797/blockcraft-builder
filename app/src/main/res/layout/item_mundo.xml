<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#2D2D44">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: Nombre + Fecha -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="1">

            <TextView
                android:id="@+id/tvNombreMundo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mi gran castillo"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFechaMundo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 Oct 2023"
                android:textColor="#8888AA"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Chips: Tipo + Bioma -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvTipoMundo"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="SUPERVIVENCIA"
                android:textColor="#FFD93D"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_gold"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvBiomaMundo"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="PRADERA"
                android:textColor="#6BCB77"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_green"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center"
                android:layout_marginStart="8dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_forward"
                android:tint="#6C63FF" />

        </LinearLayout>

        <!-- Botones de acción -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnCargarMundo"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Cargar mundo"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_primary"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <Button
                android:id="@+id/btnEliminarMundo"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="0.5"
                android:text="Eliminar"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_danger"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>