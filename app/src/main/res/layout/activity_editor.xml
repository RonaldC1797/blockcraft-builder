<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- ===== TOP APP BAR ===== -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:background="@android:color/transparent"
            android:textColor="#333333"
            android:textSize="24sp"
            android:padding="8dp" />

        <TextView
            android:id="@+id/tvProjectTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Editor"
            android:textColor="#333333"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <Switch
            android:id="@+id/switchGrid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grid"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAVE"
            android:background="@android:color/transparent"
            android:textColor="#6C63FF"
            android:textSize="14sp"
            android:textStyle="bold" />

    </androidx.appcompat.widget.Toolbar>

    <!-- ===== CANVAS 3D ISOMÉTRICO ===== -->
    <com.cacuango.blockcraft.builder.ui.editor.IsometricView
        android:id="@+id/isometricView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#E8E8E8"
        android:layout_margin="8dp" />

    <!-- ===== UNDO / REDO ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/btnUndo"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="↩ Deshacer"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_primary"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnRedo"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="↪ Rehacer"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_primary"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- ===== TABS DE CATEGORÍAS ===== -->
    <!-- ===== SELECTOR DE BLOQUES ===== -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layoutBloques"
            android:layout_width="wrap_content"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical">

            <!-- Bloque Madera -->
            <LinearLayout
                android:id="@+id/btnBloquesMadera"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_bloque_seleccionado"
                android:layout_marginEnd="8dp">
                <View
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="#B5651D"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Madera"
                    android:textSize="8sp"
                    android:textColor="#333333"/>
            </LinearLayout>

            <!-- Bloque Piedra -->
            <LinearLayout
                android:id="@+id/btnBloquesPiedra"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_bloque_normal"
                android:layout_marginEnd="8dp">
                <View
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="#808080"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Piedra"
                    android:textSize="8sp"
                    android:textColor="#333333"/>
            </LinearLayout>

            <!-- Bloque Ladrillo -->
            <LinearLayout
                android:id="@+id/btnBloquesLadrillo"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_bloque_normal"
                android:layout_marginEnd="8dp">
                <View
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="#CC4444"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ladrillo"
                    android:textSize="8sp"
                    android:textColor="#333333"/>
            </LinearLayout>

            <!-- Bloque Tierra -->
            <LinearLayout
                android:id="@+id/btnBloquesTierra"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_bloque_normal"
                android:layout_marginEnd="8dp">
                <View
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="#8B6914"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tierra"
                    android:textSize="8sp"
                    android:textColor="#333333"/>
            </LinearLayout>

            <!-- Bloque Arena -->
            <LinearLayout
                android:id="@+id/btnBloquesArena"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_bloque_normal"
                android:layout_marginEnd="8dp">
                <View
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="#F4D03F"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Arena"
                    android:textSize="8sp"
                    android:textColor="#333333"/>
            </LinearLayout>

            <!-- Bloque Cristal -->
            <LinearLayout
                android:id="@+id/btnBloquesCristal"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_bloque_normal"
                android:layout_marginEnd="8dp">
                <View
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="#85C1E9"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cristal"
                    android:textSize="8sp"
                    android:textColor="#333333"/>
            </LinearLayout>

        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>