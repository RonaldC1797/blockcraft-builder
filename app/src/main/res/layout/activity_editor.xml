<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- ===== TOP APP BAR ===== -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:background="@android:color/transparent"
            android:textColor="#333333"
            android:textSize="24sp"
            android:padding="8dp" />

        <TextView
            android:id="@+id/tvProjectTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Editor"
            android:textColor="#333333"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <Switch
            android:id="@+id/switchGrid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grid"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAVE"
            android:background="@android:color/transparent"
            android:textColor="#6C63FF"
            android:textSize="14sp"
            android:textStyle="bold" />

    </androidx.appcompat.widget.Toolbar>

    <!-- ===== CANVAS 3D ISOMÉTRICO ===== -->
    <com.cacuango.blockcraft.builder.ui.editor.IsometricView
        android:id="@+id/isometricView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#E8E8E8"
        android:layout_margin="8dp" />

    <!-- ===== UNDO / REDO ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/btnUndo"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="↩ Deshacer"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_primary"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnRedo"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="↪ Rehacer"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_primary"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- ===== TABS DE CATEGORÍAS ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tabStructure"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Estructura"
            android:gravity="center"
            android:textColor="#6C63FF"
            android:textStyle="bold"
            android:textSize="12sp"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/tabDecoration"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Decoración"
            android:gravity="center"
            android:textColor="#333333"
            android:textSize="12sp"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/tabNature"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Naturaleza"
            android:gravity="center"
            android:textColor="#333333"
            android:textSize="12sp"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/tabSpecial"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Especiales"
            android:gravity="center"
            android:textColor="#333333"
            android:textSize="12sp"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>

</LinearLayout>